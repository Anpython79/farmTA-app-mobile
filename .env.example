# ==================== BACKEND CONFIG ====================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=farmta_user
DB_PASSWORD=your_secure_password
DB_NAME=farmta_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:19000,http://localhost:19001

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Email (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@farmta.com

# AWS (Optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=farmta-bucket
AWS_REGION=ap-southeast-1

# ==================== MOBILE CONFIG ====================

# API
REACT_NATIVE_API_URL=http://localhost:8000/api/v1
API_TIMEOUT=30000

# Firebase (Optional)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Environment
NODE_ENV=development
EXPO_DEBUG=true

# ==================== COMMON CONFIG ====================

# App
APP_NAME=FarmTA
APP_VERSION=1.0.0
TIMEZONE=Asia/Ho_Chi_Minh

# Logging
LOG_TO_FILE=false
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_IOT_SENSORS=false
ENABLE_ANALYTICS=true
ENABLE_SOCIAL_FEATURES=false
ENABLE_ECOMMERCE=false
