{
  "name": "farmta-app-mobile",
  "version": "1.0.0",
  "description": "Mobile app for farm management - Ứng dụng quản lý trang trại",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace farmTA.xcworkspace -scheme farmTA -configuration Release",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.20.0",
    "react-native-safe-area-context": "^4.5.0",
    "axios": "^1.4.0",
    "redux": "^4.2.1",
    "react-redux": "^8.1.1",
    "redux-thunk": "^2.4.2",
    "moment": "^2.29.4",
    "react-native-vector-icons": "^9.2.0",
    "react-native-gesture-handler": "^2.12.0",
    "react-native-reanimated": "^3.3.0",
    "react-native-maps": "^1.10.0",
    "react-native-camera": "^4.2.1",
    "react-native-file-viewer": "^2.1.4",
    "react-native-image-picker": "^5.4.0",
    "react-native-permissions": "^3.10.0",
    "react-native-document-picker": "^9.0.0",
    "react-native-share": "^8.0.1",
    "react-native-toast-message": "^2.1.5",
    "react-native-netinfo": "^9.3.5",
    "react-native-device-info": "^10.3.0",
    "react-native-splash-screen": "^3.3.0",
    "react-native-linear-gradient": "^2.8.1",
    "react-native-shadow-2": "^5.1.0",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.22.0",
    "@testing-library/react-native": "^12.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "jest": "^29.5.0",
    "jest-mock-extended": "^3.0.4",
    "eslint": "^8.42.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^2.8.8",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.1.0",
    "metro-react-native-babel-preset": "^0.76.8",
    "babel-jest": "^29.5.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-navigation|@react-native-community|react-native-vector-icons|react-native-reanimated)/)"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "author": "Anpython79",
  "license": "MIT"
}
